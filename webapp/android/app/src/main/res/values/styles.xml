<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Thème principal : fond #070707, accent #C8FF00 -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#C8FF00</item>
        <item name="colorPrimaryDark">#070707</item>
        <item name="colorAccent">#C8FF00</item>
        <item name="android:windowBackground">#070707</item>
        <item name="android:statusBarColor">#070707</item>
        <item name="android:navigationBarColor">#070707</item>
        <!-- Icônes barres système claires sur fond sombre -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Edge-to-edge : contenu sous notch et barres système -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:statusBarColor">#070707</item>
        <item name="android:navigationBarColor">#070707</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Splash screen : zéro flash blanc au démarrage -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:statusBarColor">#070707</item>
        <item name="android:navigationBarColor">#070707</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="windowSplashScreenBackground">#070707</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

</resources>
